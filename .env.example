# ZAI (Z.ai) — API key from https://api.z.ai dashboard
ZAI_API_KEY=

# Claude (Anthropic) — OAuth token or API key used for /api/oauth/usage
# NOTE: Endpoint requires verification. See collectors/claude.mjs
CLAUDE_OAUTH_TOKEN=

# Codex (ChatGPT plan) — path to auth.json written by `codex` CLI (contains access_token)
# Default: ~/.codex/auth.json
CODEX_AUTH_JSON=

# Ollama Cloud — value of __Secure-session cookie from ollama.com
# Extract via Chrome DevTools -> Application -> Cookies -> ollama.com
# HttpOnly cookie, must be copied manually. Refresh when it expires (~1 week).
OLLAMA_SESSION_COOKIE=

# Optional: port for web dashboard
USAGE_MONITOR_PORT=3030
